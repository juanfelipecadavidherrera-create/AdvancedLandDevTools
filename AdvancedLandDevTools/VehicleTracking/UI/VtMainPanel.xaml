<UserControl x:Class="AdvancedLandDevTools.VehicleTracking.UI.VtMainPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E" Foreground="#E0E0E0">

    <UserControl.Resources>
        <!-- Dark scrollbar style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Dark button style -->
        <Style x:Key="VtButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A6EA5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D5A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button (blue) -->
        <Style x:Key="VtActionButton" TargetType="Button" BasedOn="{StaticResource VtButton}">
            <Setter Property="Background" Value="#0D47A1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Dark combobox -->
        <Style x:Key="VtCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#60CDFF"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>

        <!-- Info label -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Tab control with dark theme -->
        <TabControl Background="#1E1E1E" BorderBrush="#333"
                    Foreground="#E0E0E0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#252525"/>
                    <Setter Property="Foreground" Value="#999"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#60CDFF"/>
                                        <Setter Property="Foreground" Value="#E0E0E0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════ SWEPT PATH TAB ═══════════════ -->
            <TabItem Header="Swept Path">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="VEHICLE"/>
                        <ComboBox x:Name="CmbVehicle" Style="{StaticResource VtCombo}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Category: " Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtCategory" Style="{StaticResource InfoLabel}" Foreground="#FFB74D"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Dimensions: " Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtDimensions" Style="{StaticResource InfoLabel}" Foreground="#FFB74D"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Min Radius: " Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtMinRadius" Style="{StaticResource InfoLabel}" Foreground="#FFB74D"/>
                        </StackPanel>

                        <!-- Vehicle preview canvas -->
                        <Border Background="#0D0D0D" CornerRadius="6" Margin="0,8,0,0"
                                BorderBrush="#333" BorderThickness="1">
                            <Canvas x:Name="VehiclePreview" Height="100" ClipToBounds="True"/>
                        </Border>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="PATH"/>
                        <Button x:Name="BtnPickPath" Content="Pick Path Polyline"
                                Style="{StaticResource VtButton}" Click="BtnPickPath_Click"/>

                        <TextBlock x:Name="TxtPathInfo" Style="{StaticResource InfoLabel}"
                                   Text="No path selected" Margin="0,4,0,0"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="OPTIONS"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="RdForward" Content="Forward" IsChecked="True"
                                         Foreground="#E0E0E0" Margin="0,0,16,0"/>
                            <RadioButton x:Name="RdReverse" Content="Reverse"
                                         Foreground="#E0E0E0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Speed (mph): " VerticalAlignment="Center"
                                       Foreground="#CCC" FontSize="11"/>
                            <TextBox x:Name="TxtSpeed" Text="15" Width="50"
                                     Background="#2D2D2D" Foreground="#E0E0E0"
                                     BorderBrush="#3D3D3D" Padding="4,2"/>
                        </StackPanel>

                        <Button x:Name="BtnRunSweep" Content="RUN SWEPT PATH ANALYSIS"
                                Style="{StaticResource VtActionButton}" Margin="0,10,0,0"
                                Click="BtnRunSweep_Click"/>

                        <!-- Results -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="RESULTS"
                                   x:Name="TxtResultsHeader" Visibility="Collapsed"/>
                        <StackPanel x:Name="PnlResults" Visibility="Collapsed">
                            <TextBlock x:Name="TxtResultPath" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtResultWidth" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtResultOT" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtResultClamped" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="TxtResultCollisions" Style="{StaticResource InfoLabel}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ PARKING TAB ═══════════════ -->
            <TabItem Header="Parking">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="BOUNDARY"/>
                        <Button x:Name="BtnPickBoundary" Content="Pick Parking Boundary"
                                Style="{StaticResource VtButton}" Click="BtnPickBoundary_Click"/>
                        <TextBlock x:Name="TxtBoundaryInfo" Style="{StaticResource InfoLabel}"
                                   Text="No boundary selected"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="PARKING ANGLE"/>
                        <ComboBox x:Name="CmbAngle" Style="{StaticResource VtCombo}"
                                  SelectionChanged="CmbAngle_SelectionChanged">
                            <ComboBoxItem Content="90° (Perpendicular)" IsSelected="True"/>
                            <ComboBoxItem Content="60°"/>
                            <ComboBoxItem Content="45°"/>
                            <ComboBoxItem Content="30°"/>
                            <ComboBoxItem Content="Parallel"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="DIMENSIONS (Florida Defaults)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Stall Width:"
                                       Style="{StaticResource InfoLabel}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtStallWidth" Grid.Row="0" Grid.Column="1"
                                     Text="9.0" Background="#2D2D2D" Foreground="#E0E0E0"
                                     BorderBrush="#3D3D3D" Padding="4,2" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Stall Depth:"
                                       Style="{StaticResource InfoLabel}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtStallDepth" Grid.Row="1" Grid.Column="1"
                                     Text="18.5" Background="#2D2D2D" Foreground="#E0E0E0"
                                     BorderBrush="#3D3D3D" Padding="4,2" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Aisle Width:"
                                       Style="{StaticResource InfoLabel}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtAisleWidth" Grid.Row="2" Grid.Column="1"
                                     Text="24.0" Background="#2D2D2D" Foreground="#E0E0E0"
                                     BorderBrush="#3D3D3D" Padding="4,2" Margin="0,2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ADA Spaces:"
                                       Style="{StaticResource InfoLabel}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtAdaCount" Grid.Row="3" Grid.Column="1"
                                     Text="1" Background="#2D2D2D" Foreground="#E0E0E0"
                                     BorderBrush="#3D3D3D" Padding="4,2" Margin="0,2"/>
                        </Grid>

                        <Button x:Name="BtnGenerateParking" Content="GENERATE PARKING LAYOUT"
                                Style="{StaticResource VtActionButton}" Margin="0,12,0,0"
                                Click="BtnGenerateParking_Click"/>

                        <TextBlock x:Name="TxtParkingResult" Style="{StaticResource InfoLabel}"
                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ VEHICLE LIBRARY TAB ═══════════════ -->
            <TabItem Header="Library">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="DESIGN VEHICLES"/>

                        <TextBox x:Name="TxtSearch" Background="#2D2D2D" Foreground="#E0E0E0"
                                 BorderBrush="#3D3D3D" Padding="6,4"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <TextBlock Text="Search vehicles..." Foreground="#666"
                                   FontSize="11" Margin="8,-20,0,6" IsHitTestVisible="False"
                                   x:Name="TxtSearchPlaceholder"/>

                        <ListBox x:Name="LstVehicles" Background="#1E1E1E" Foreground="#E0E0E0"
                                 BorderBrush="#333" MaxHeight="300"
                                 SelectionChanged="LstVehicles_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <TextBlock Text="{Binding Symbol}" Foreground="#60CDFF"
                                                   FontWeight="SemiBold" Width="90"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#CCC"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="DETAILS"/>
                        <TextBlock x:Name="TxtLibDetails" Style="{StaticResource InfoLabel}"
                                   TextWrapping="Wrap" Text="Select a vehicle to see details."/>

                        <!-- Vehicle preview -->
                        <Border Background="#0D0D0D" CornerRadius="6" Margin="0,8,0,0"
                                BorderBrush="#333" BorderThickness="1">
                            <Canvas x:Name="LibraryPreview" Height="120" ClipToBounds="True"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
