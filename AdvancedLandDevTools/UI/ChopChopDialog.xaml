<Window
    x:Class="AdvancedLandDevTools.UI.ChopChopDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Advanced Land Development Tools – ChopChop"
    Width="620" Height="560"
    MinWidth="540" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             HEADER
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource AldtHeader}"
                Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="38" Height="38"
                        Background="{StaticResource AldtAccentBtn}"
                        CornerRadius="8"
                        Margin="0,0,14,0">
                    <TextBlock Text="✂" Foreground="White" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADVANCED LAND DEVELOPMENT TOOLS"
                               Foreground="{StaticResource AldtAccent}" FontSize="9"
                               FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock Text="ChopChop — Profile View Subdivider"
                               Foreground="White" FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             BODY
             ════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,16,20,8">
            <StackPanel>

                <!-- ── SOURCE PROFILE VIEW INFO ──────────────────────────── -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="SOURCE PROFILE VIEW"
                                   Style="{StaticResource FluentSectionTitle}"/>
                        <TextBlock x:Name="TxtPvInfo"
                                   Text="(none selected)"
                                   Foreground="{StaticResource AldtText}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ── SUBDIVISION MODE ──────────────────────────────────── -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="SUBDIVISION MODE"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="RbEqual"
                                         Content="Equal Subdivision"
                                         Foreground="{StaticResource AldtText}"
                                         FontSize="13"
                                         IsChecked="True"
                                         GroupName="Mode"
                                         Checked="RbMode_Checked"
                                         Margin="0,0,24,0"/>
                            <RadioButton x:Name="RbCustom"
                                         Content="Custom Intervals"
                                         Foreground="{StaticResource AldtText}"
                                         FontSize="13"
                                         GroupName="Mode"
                                         Checked="RbMode_Checked"/>
                        </StackPanel>

                        <!-- ── Equal Mode Panel ──────────────────────────── -->
                        <StackPanel x:Name="PnlEqual">
                            <TextBlock Text="Segment Length (ft)"
                                       Style="{StaticResource FluentFieldLabel}"/>
                            <TextBox x:Name="TxtSegmentLength"
                                     Style="{StaticResource FluentTextBox}"
                                     Text="500"
                                     TextChanged="TxtSegmentLength_TextChanged"
                                     ToolTip="e.g. 500 — each sub-view will be this many feet wide"/>

                            <TextBlock x:Name="TxtPreview"
                                       Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       Text=""/>
                        </StackPanel>

                        <!-- ── Custom Mode Panel ─────────────────────────── -->
                        <StackPanel x:Name="PnlCustom" Visibility="Collapsed">
                            <!-- Header row -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Start Station"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBlock Grid.Column="2" Text="End Station"
                                           Style="{StaticResource FluentFieldLabel}"/>
                            </Grid>

                            <!-- Interval rows -->
                            <Border Background="{StaticResource AldtSurface}"
                                    CornerRadius="6" Padding="6"
                                    MaxHeight="180">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="IntervalItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="36"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding StartText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FluentTextBox}"
                                                             ToolTip="e.g. 0+00 or 0"/>
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding EndText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FluentTextBox}"
                                                             ToolTip="e.g. 5+00 or 500"/>
                                                    <Button Grid.Column="3"
                                                            Content="✕"
                                                            Style="{StaticResource FluentSecondaryBtn}"
                                                            Padding="4,4"
                                                            FontSize="11"
                                                            Margin="4,0,0,0"
                                                            Click="BtnRemoveInterval_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Remove this interval"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Button x:Name="BtnAddInterval"
                                    Content="+ Add Interval"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Padding="12,5"
                                    FontSize="11"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    Click="BtnAddInterval_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── LAYOUT SETTINGS ───────────────────────────────────── -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="LAYOUT"
                                   Style="{StaticResource FluentSectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vertical Offset (ft)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtVerticalOffset"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="500"
                                         ToolTip="Distance below original PV to place first sub-view"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Horizontal Gap (ft)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtHorizontalGap"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="100"
                                         ToolTip="Gap between sub-views arranged side by side"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Sub-views are placed horizontally, left to right, in station order."
                                   Style="{StaticResource FluentHint}"/>
                    </StackPanel>
                </Border>

                <!-- Validation message -->
                <TextBlock x:Name="TxtValidation"
                           Foreground="{StaticResource AldtError}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ════════════════════════════════════════════════════════════════
             FOOTER
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource AldtHeader}"
                Padding="20,12">
            <Grid>
                <TextBlock Text="Original profile view is kept. Sub-views placed below."
                           Foreground="{StaticResource AldtTextTertiary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Style="{StaticResource FluentSecondaryBtn}"
                            IsCancel="True"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnOk"
                            Content="OK"
                            Style="{StaticResource FluentPrimaryBtn}"
                            IsDefault="True"
                            Margin="12,0,0,0"
                            Click="BtnOk_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
