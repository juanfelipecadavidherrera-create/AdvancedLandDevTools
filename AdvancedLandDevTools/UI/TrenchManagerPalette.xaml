<UserControl
    x:Class="AdvancedLandDevTools.UI.TrenchManagerPalette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#202020" MinWidth="280">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#383838" BorderBrush="#454545"
                                    BorderThickness="1" CornerRadius="5" Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#424242"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#606060"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#353535"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SmallIconBtn" TargetType="Button">
                <Setter Property="Foreground" Value="#9E9E9E"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Width" Value="26"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DeleteIconBtn" TargetType="Button">
                <Setter Property="Foreground" Value="#9E9E9E"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Width" Value="26"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#33FF6B6B"/>
                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- ══════════════════════════════════════════════════════════════
             HEADER — Project selector
             ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#1A1A1A" Padding="10,8"
                BorderBrush="#454545" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="#FF8A65" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="EXF Trench Manager" FontSize="14" FontWeight="SemiBold"
                               Foreground="#FF8A65" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtProjectName" Grid.Column="0"
                             Style="{StaticResource FluentTextBox}"
                             ToolTip="Type a project name, then press Enter or click +"
                             KeyDown="TxtProjectName_KeyDown"/>

                    <Button Grid.Column="1" Content="&#xE70D;" Style="{StaticResource SmallIconBtn}"
                            FontSize="12" Width="30" Height="30" Margin="2,0,0,0"
                            ToolTip="Load existing project" Click="BtnShowProjects_Click"/>

                    <Button Grid.Column="2" Content="&#xE710;" Style="{StaticResource SmallIconBtn}"
                            FontSize="14" Width="30" Height="30" Margin="2,0,0,0"
                            ToolTip="Create / Load project" Click="BtnLoadProject_Click"/>

                    <Button Grid.Column="3" Content="&#xE74D;" Style="{StaticResource DeleteIconBtn}"
                            FontSize="14" Width="30" Height="30" Margin="2,0,0,0"
                            ToolTip="Delete project" Click="BtnDeleteProject_Click"/>
                </Grid>

                <!-- Project dropdown popup -->
                <Popup x:Name="ProjectPopup" Placement="Bottom"
                       PlacementTarget="{Binding ElementName=TxtProjectName}"
                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="#2D2D2D" BorderBrush="#454545" BorderThickness="1"
                            CornerRadius="6" Padding="4" MinWidth="200" MaxHeight="200">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.4" ShadowDepth="3" Color="Black"/>
                        </Border.Effect>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ProjectList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ProjItem" Background="Transparent"
                                                CornerRadius="4" Padding="10,6" Margin="0,1"
                                                Cursor="Hand" MouseLeftButtonUp="ProjectItem_Click">
                                            <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="12"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <Trigger SourceName="ProjItem" Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ProjItem" Property="Background" Value="#383838"/>
                                            </Trigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             ACTION BAR
             ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#252526" Padding="8,6"
                BorderBrush="#454545" BorderThickness="0,0,0,1">
            <WrapPanel>
                <Button x:Name="BtnAddTrench" Style="{StaticResource ActionBtn}"
                        Click="BtnAddTrench_Click"
                        ToolTip="Select a polyline — stores its longest segment length">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Add Trench" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             SUMMARY BAR
             ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="10,5"
                BorderBrush="#383838" BorderThickness="0,0,0,1">
            <TextBlock x:Name="TxtSummary" Text="No project loaded"
                       FontSize="11" Foreground="#9E9E9E"/>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             RENAME POPUP
             ══════════════════════════════════════════════════════════════ -->
        <Popup x:Name="RenamePopup" Placement="Center"
               PlacementTarget="{Binding ElementName=TxtSummary}"
               StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="#2D2D2D" BorderBrush="#60CDFF" BorderThickness="1"
                    CornerRadius="8" Padding="14" MinWidth="220">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="3" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Rename Trench" Foreground="#60CDFF"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtRenameOldName" Foreground="#9E9E9E"
                               FontSize="10" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtRenameName" Style="{StaticResource FluentTextBox}"
                             KeyDown="TxtRenameName_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="OK" Style="{StaticResource FluentPrimaryBtn}"
                                Padding="14,5" Click="BtnConfirmRename_Click"/>
                        <Button Content="Cancel" Style="{StaticResource FluentSecondaryBtn}"
                                Padding="10,5" Margin="6,0,0,0" Click="BtnCancelRename_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ══════════════════════════════════════════════════════════════
             TRENCH LIST
             ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="TrenchListPanel" Margin="8,6,8,8"/>
        </ScrollViewer>

    </DockPanel>
</UserControl>
