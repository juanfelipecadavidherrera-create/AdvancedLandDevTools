<Window
    x:Class="AdvancedLandDevTools.UI.VtDrivePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vehicle Tracking — Interactive Drive"
    Width="270" SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    Left="80" Top="120"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- ── Dark Button ─────────────────────────────────────── -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent Button ───────────────────────────────────── -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#1B6EC2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ── Dark ComboBox Toggle Button ─────────────────────── -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Bd" Grid.ColumnSpan="2"
                        Background="#383838" BorderBrush="#454545"
                        BorderThickness="1" CornerRadius="6"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Fill="#9E9E9E" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 5 5 L 10 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush">
                        <Setter.Value><SolidColorBrush Color="#606060"/></Setter.Value>
                    </Setter>
                    <Setter TargetName="Arrow" Property="Fill">
                        <Setter.Value><SolidColorBrush Color="#E0E0E0"/></Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush">
                        <Setter.Value><SolidColorBrush Color="#60CDFF"/></Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ── Dark ComboBox (matches FluentDarkTheme) ─────────── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4" Margin="2,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background">
                                                <Setter.Value><SolidColorBrush Color="#383838"/></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background">
                                                <Setter.Value><SolidColorBrush Color="#424242"/></Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,28,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#2D2D2D" BorderBrush="#454545"
                                            BorderThickness="1" CornerRadius="8" Padding="0,4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" Opacity="0.4"
                                                              ShadowDepth="4" Color="Black"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#E6181818" BorderBrush="#60CDFF" BorderThickness="1"
            CornerRadius="10" Padding="12,10" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="3" Color="Black"/>
        </Border.Effect>

        <StackPanel>
            <!-- Title bar -->
            <Grid Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE804;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="#60CDFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Interactive Drive" Foreground="#60CDFF"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="BtnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                        FontSize="10" HorizontalAlignment="Right" Click="BtnClose_Click"
                        Style="{StaticResource DarkBtn}" Padding="4,2"/>
            </Grid>

            <Border Height="1" Background="#333" Margin="0,0,0,8"/>

            <!-- Vehicle Selector -->
            <TextBlock Text="VEHICLE" Foreground="#888" FontSize="9" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="CboVehicle" Style="{StaticResource DarkCombo}"
                      MaxDropDownHeight="300"
                      SelectionChanged="CboVehicle_Changed"/>

            <!-- Vehicle info -->
            <TextBlock x:Name="TxtVehicleInfo" Foreground="#999" FontSize="9"
                       Margin="0,4,0,4" TextWrapping="Wrap"/>

            <!-- Place Detail Block button -->
            <Button x:Name="BtnPlaceBlock" Style="{StaticResource DarkBtn}"
                    Margin="0,2,0,8" HorizontalContentAlignment="Center"
                    Click="BtnPlaceBlock_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="#60CDFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Place Detail Block" FontSize="11"
                               Foreground="#E0E0E0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Border Height="1" Background="#333" Margin="0,0,0,8"/>

            <!-- Speed -->
            <TextBlock Text="SPEED" Foreground="#888" FontSize="9" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SldSpeed" Minimum="2" Maximum="40" Value="15"
                        TickFrequency="5" IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="SldSpeed_Changed"/>
                <TextBlock x:Name="TxtSpeed" Grid.Column="1" Foreground="#E0E0E0"
                           FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Text="15 mph"/>
            </Grid>

            <Border Height="1" Background="#333" Margin="0,8,0,8"/>

            <!-- Mode / Status -->
            <TextBlock x:Name="TxtStatus" Foreground="#66BB6A" FontSize="11"
                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="Select vehicle, then click in drawing to place start point..."/>

            <!-- Action Buttons -->
            <StackPanel x:Name="PnlActions" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,4">
                <Button x:Name="BtnUndo" Content="Undo" Style="{StaticResource DarkBtn}"
                        Width="70" Margin="0,0,6,0" Click="BtnUndo_Click" IsEnabled="False"/>
                <Button x:Name="BtnFinish" Content="Finish" Style="{StaticResource AccentBtn}"
                        Width="70" Margin="0,0,6,0" Click="BtnFinish_Click" IsEnabled="False"/>
                <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource DarkBtn}"
                        Width="70" Click="BtnCancel_Click"/>
            </StackPanel>

            <!-- Edit mode section (hidden until path is created) -->
            <StackPanel x:Name="PnlEdit" Visibility="Collapsed" Margin="0,8,0,0">
                <Border Height="1" Background="#333" Margin="0,0,0,8"/>
                <TextBlock Text="EDIT MODE" Foreground="#FFB74D" FontSize="9"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Foreground="#999" FontSize="10" TextWrapping="Wrap"
                           Text="Click any X marker to drag-edit arcs in real time."/>
                <Button x:Name="BtnAccept" Content="Accept Path" Style="{StaticResource AccentBtn}"
                        Margin="0,6,0,0" Click="BtnAccept_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
