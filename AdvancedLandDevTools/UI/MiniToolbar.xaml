<Window
    x:Class="AdvancedLandDevTools.UI.MiniToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ALDT"
    Width="52" SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    Left="60" Top="200"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer border — the visible toolbar frame -->
    <Border x:Name="MainBorder"
            Background="#E6202020"
            BorderBrush="#60CDFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="4,6"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5"
                              ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <StackPanel x:Name="PanelContent">

            <!-- ── Drag handle + Settings + Close ────────────────── -->
            <Grid Margin="0,0,0,2">
                <TextBlock Text="ALDT"
                           Foreground="#60CDFF"
                           FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.7"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,-2,-2,0">
                    <!-- Settings gear -->
                    <Button x:Name="BtnSettings"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Click="BtnSettings_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Customize visible commands"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3360CDFF"/>
                                                    <Setter Property="Foreground" Value="#60CDFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Close X -->
                    <Button x:Name="BtnClose"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FF6B6B"/>
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Settings popup ────────────────────────────────── -->
            <Popup x:Name="SettingsPopup" Placement="Right"
                   PlacementTarget="{Binding ElementName=BtnSettings}"
                   StaysOpen="False" AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#E6202020" BorderBrush="#60CDFF" BorderThickness="1"
                        CornerRadius="8" Padding="10" MinWidth="180" MaxHeight="400">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="3" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Visible Commands" Foreground="#60CDFF"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <StackPanel x:Name="SettingsPanel"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>

            <Border Height="1" Background="#454545" Margin="2,2,2,4"/>

            <!-- ── Profile Views Section ──────────────────────────── -->
            <TextBlock Text="PROFILES" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- BSP — Blue (profile/chart) -->
            <Button Tag="BULKSUR " ToolTip="Bulk Surface Profile (BULKSUR)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#4FC3F7"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Bulk" FontSize="7" Foreground="#4FC3F7"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334FC3F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- GP — Teal (find/search) -->
            <Button Tag="GETPARENT " ToolTip="Get Parent Alignment (GETPARENT)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#4DB6AC"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Parent" FontSize="7" Foreground="#4DB6AC"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334DB6AC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- PM — Purple (magic/pipe) -->
            <Button Tag="PIPEMAGIC " ToolTip="Pipe Magic (PIPEMAGIC)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#BA68C8"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Magic" FontSize="7" Foreground="#BA68C8"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33BA68C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ML — Yellow-orange (mark/highlight) -->
            <Button Tag="MARKLINES " ToolTip="Mark Lines (MARKLINES)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xED63;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#FFB74D"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Mark" FontSize="7" Foreground="#FFB74D"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFB74D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Height="1" Background="#454545" Margin="2,4,2,4"/>

            <!-- ── Alignments Section ─────────────────────────────── -->
            <TextBlock Text="ALIGN" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- AD — Green (deploy/copy) -->
            <Button Tag="ALIGNDEPLOY " ToolTip="Align Deploy (ALIGNDEPLOY)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#81C784"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Deploy" FontSize="7" Foreground="#81C784"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3381C784"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Height="1" Background="#454545" Margin="2,4,2,4"/>

            <!-- ── Pipes Section ──────────────────────────────────── -->
            <TextBlock Text="PIPES" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- IP — Amber/gold (invert/elevation) -->
            <Button Tag="INVERTPULLUP " ToolTip="Invert Pull Up (INVERTPULLUP)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#FFD54F"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Invert" FontSize="7" Foreground="#FFD54F"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFD54F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- CE — Orange (change/edit) -->
            <Button Tag="CHANGEELEVATION " ToolTip="Change Elevation (CHANGEELEVATION)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#FF8A65"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Elev" FontSize="7" Foreground="#FF8A65"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FF8A65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- EEE — Cyan (pressure pipe duck) -->
            <Button Tag="EEEBEND " ToolTip="EEE Bend — Pressure Pipe Duck (EEEBEND)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE76E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#29B6F6"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Duck" FontSize="7" Foreground="#29B6F6"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3329B6F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Height="1" Background="#454545" Margin="2,4,2,4"/>

            <!-- ── Surfaces Section ──────────────────────────────── -->
            <TextBlock Text="SURFACES" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- ES — Green (slope) -->
            <Button Tag="ELEVSLOPE " ToolTip="Elevation Sloper (ELEVSLOPE)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE879;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#66BB6A"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Slope" FontSize="7" Foreground="#66BB6A"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3366BB6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- B2S — Orange (block to surface) -->
            <Button Tag="BLOCKTOSURFACE " ToolTip="Block to Surface (BLOCKTOSURFACE)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#FF7043"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="B2S" FontSize="7" Foreground="#FF7043"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FF7043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- T2S — Cyan (text to surface) -->
            <Button Tag="TEXTTOSURFACE " ToolTip="Text to Surface (TEXTTOSURFACE)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#4DD0E1"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="T2S" FontSize="7" Foreground="#4DD0E1"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334DD0E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- LR — Red/amber (lowest rim) -->
            <Button Tag="LOWRIM " ToolTip="Lowest Rim Elevation (LOWRIM)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#EF5350"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="LoRim" FontSize="7" Foreground="#EF5350"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33EF5350"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Height="1" Background="#454545" Margin="2,4,2,4"/>

            <!-- ── Property Info Section ──────────────────────────── -->
            <TextBlock Text="INFO" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- FZ — Red (FEMA flood danger) -->
            <Button Tag="FLOODZONE " ToolTip="FEMA Flood Zone (FLOODZONE)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#EF5350"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="FEMA" FontSize="7" Foreground="#EF5350"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33EF5350"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- FC — Deep orange (county flood) -->
            <Button Tag="FLOODCRITERIA " ToolTip="County Flood Criteria (FLOODCRITERIA)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE81D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#FF7043"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="County" FontSize="7" Foreground="#FF7043"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FF7043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- SS — Lime green (section/map) -->
            <Button Tag="SECTIONLOOKUP " ToolTip="Section Lookup SSTTRR (SECTIONLOOKUP)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#AED581"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="PLSS" FontSize="7" Foreground="#AED581"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33AED581"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- GWMAY — Cyan/water (water table May) -->
            <Button Tag="GWMAY " ToolTip="Water Table — Avg May (GWMAY)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#29B6F6"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="GWMay" FontSize="7" Foreground="#29B6F6"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3329B6F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- GWOCT — Blue/water (water table Oct) -->
            <Button Tag="GWOCT " ToolTip="Water Table — Oct 2040 (GWOCT)"
                    Click="ToolButton_Click" Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="38" Height="34"
                                Background="Transparent" CornerRadius="6"
                                Margin="1" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Foreground="#42A5F5"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="GWOct" FontSize="7" Foreground="#42A5F5"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3342A5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border Height="1" Background="#454545" Margin="2,4,2,4"/>

            <!-- ── Area Manager Section ─────────────────────────────── -->
            <TextBlock Text="AREAS" Foreground="#60CDFF" FontSize="7.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Margin="0,0,0,3" Opacity="0.6"/>

            <!-- AM — Green (area/grid) -->
            <Button Tag="AREAMANAGER " ToolTip="Area Manager (AREAMANAGER)"
