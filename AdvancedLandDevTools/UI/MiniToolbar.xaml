<Window
    x:Class="AdvancedLandDevTools.UI.MiniToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ALDT"
    Width="200" SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    Left="60" Top="200"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer border — the visible toolbar frame -->
    <Border x:Name="MainBorder"
            Background="#E6202020"
            BorderBrush="#60CDFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="6"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5"
                              ShadowDepth="2" Color="Black"/>
        </Border.Effect>

        <StackPanel x:Name="PanelContent">

            <!-- ── Drag handle + Settings + Close ────────────────── -->
            <Grid Margin="0,0,0,2">
                <TextBlock Text="ALDT"
                           Foreground="#60CDFF"
                           FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.7"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,-2,-2,0">
                    <!-- Settings gear -->
                    <Button x:Name="BtnSettings"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Click="BtnSettings_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Customize visible commands"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3360CDFF"/>
                                                    <Setter Property="Foreground" Value="#60CDFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Close X -->
                    <Button x:Name="BtnClose"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Width" Value="16"/>
                                <Setter Property="Height" Value="16"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FF6B6B"/>
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Settings popup ────────────────────────────────── -->
            <Popup x:Name="SettingsPopup" Placement="Right"
                   PlacementTarget="{Binding ElementName=BtnSettings}"
                   StaysOpen="False" AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#E6202020" BorderBrush="#60CDFF" BorderThickness="1"
                        CornerRadius="8" Padding="10" MinWidth="180" MaxHeight="400">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="3" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Visible Commands" Foreground="#60CDFF"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <StackPanel x:Name="SettingsPanel"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>

            <Border Height="1" Background="#454545" Margin="2,2,2,4"/>

            <!-- ── Dynamic content generated in code-behind ───── -->
            <StackPanel x:Name="ButtonContainer"/>

        </StackPanel>
    </Border>
</Window>
