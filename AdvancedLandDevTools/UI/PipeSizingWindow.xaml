<Window
    x:Class="AdvancedLandDevTools.UI.PipeSizingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Pipe Sizing Calculator"
    Width="560" Height="720"
    MinWidth="520" MinHeight="680"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ══════ Header Bar ══════ -->
        <Border DockPanel.Dock="Top" Height="52"
                Background="{StaticResource AldtHeader}">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <Border Width="34" Height="34"
                        Background="{StaticResource AldtAccentBtn}"
                        CornerRadius="8" Margin="0,0,14,0">
                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets"
                               Foreground="White" FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADVANCED LAND DEVELOPMENT TOOLS"
                               Foreground="{StaticResource AldtAccent}" FontSize="9"
                               FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock Text="Pipe Sizing Calculator"
                               Foreground="White" FontSize="14"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════ Bottom Buttons ══════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource AldtHeader}"
                Padding="20,12">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Button Content="Suggest Min. Diameter"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnSuggest_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Close"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnClose_Click"/>
                    <Button Content="Calculate"
                            Style="{StaticResource FluentPrimaryBtn}"
                            Margin="10,0,0,0"
                            Click="BtnCalculate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ Scrollable Content ══════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="20,14,20,0">
            <StackPanel>

                <!-- ── HYDROLOGY INPUTS ── -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="HYDROLOGY — Runoff Demand (Rational Method)"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <!-- ── Area Manager Picker (collapsible) ── -->
                        <Border Margin="0,0,0,10" CornerRadius="6"
                                BorderThickness="1" BorderBrush="{StaticResource AldtBorder}">
                            <StackPanel>
                                <!-- Toggle header -->
                                <Button x:Name="BtnToggleAreaMgr"
                                        Click="BtnToggleAreaMgr_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="10,7" HorizontalContentAlignment="Left"
                                        Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TxtToggleArrow"
                                                   Text="▶" Foreground="{StaticResource AldtAccent}"
                                                   FontSize="9" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="From Area Manager"
                                                   Foreground="{StaticResource AldtAccent}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Expandable body -->
                                <StackPanel x:Name="PnlAreaMgr" Visibility="Collapsed"
                                            Margin="10,0,10,10">

                                    <!-- Project selector row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CboProject"
                                                  Style="{StaticResource FluentComboBox}"
                                                  SelectionChanged="CboProject_SelectionChanged"/>
                                        <Button Grid.Column="2" Content="↺"
                                                Style="{StaticResource FluentSecondaryBtn}"
                                                Padding="8,4" FontSize="14"
                                                ToolTip="Reload project list"
                                                Click="BtnReloadProjects_Click"/>
                                    </Grid>

                                    <!-- SubProject scope selector -->
                                    <Grid Margin="0,0,0,8"
                                          x:Name="PnlSubProjectScope"
                                          Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Scope:"
                                                   Foreground="{StaticResource AldtTextSecondary}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <ComboBox Grid.Column="1" x:Name="CboAmSubProject"
                                                  Style="{StaticResource FluentComboBox}"
                                                  SelectionChanged="CboAmSubProject_SelectionChanged"/>
                                    </Grid>

                                    <!-- Area checklist -->
                                    <Border MaxHeight="160" BorderThickness="1"
                                            BorderBrush="{StaticResource AldtBorder}"
                                            CornerRadius="4" Margin="0,0,0,8">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="PnlAreaList" Margin="4"/>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Total + Apply row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Selected total:"
                                                       Foreground="{StaticResource AldtTextSecondary}"
                                                       FontSize="11"/>
                                            <TextBlock x:Name="LblAreaTotal"
                                                       Text="0 sq ft  (0.000 ac)"
                                                       Foreground="White" FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Apply to Area ↓"
                                                Style="{StaticResource FluentPrimaryBtn}"
                                                Padding="10,5"
                                                Click="BtnApplyArea_Click"/>
                                    </Grid>

                                    <!-- No-projects hint -->
                                    <TextBlock x:Name="LblNoProjects"
                                               Text="No Area Manager projects found."
                                               Foreground="{StaticResource AldtTextSecondary}"
                                               FontSize="11" FontStyle="Italic"
                                               Visibility="Collapsed" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Drainage Area -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Drainage Area (sq ft)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtArea"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="43560" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- Row 0: Runoff Coefficient -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource FluentFieldLabel}">
                                    <Run Text="Runoff Coefficient (c)"/>
                                </TextBlock>
                                <TextBox x:Name="TxtC"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="0.90" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- Row 1: Rainfall Intensity -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Rainfall Intensity (in/hr)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtI"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="6.00" Margin="0,0,0,4"/>
                            </StackPanel>

                            <!-- Row 1: hint -->
                            <StackPanel Grid.Row="1" Grid.Column="2"
                                        VerticalAlignment="Bottom" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource FluentHint}"
                                           Text="Q = c x i x A  (Rational Method)"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── HYDRAULICS INPUTS ── -->
                <Border Style="{StaticResource FluentCard}">
                    <StackPanel>
                        <TextBlock Text="HYDRAULICS — Pipe Capacity (Manning's Equation)"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Pipe Diameter -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Pipe Diameter (inches)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtDiam"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="18" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- Row 0: Manning's n + material picker -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Manning's n"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <ComboBox x:Name="CboMaterial"
                                          Style="{StaticResource FluentComboBox}"
                                          Margin="0,0,0,4"
                                          SelectionChanged="CboMaterial_SelectionChanged"/>
                                <TextBox x:Name="TxtN"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="0.013" Margin="0,0,0,10"/>
                            </StackPanel>

                            <!-- Row 1: Pipe Slope -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Pipe Slope (decimal, e.g. 0.005)"
                                           Style="{StaticResource FluentFieldLabel}"/>
                                <TextBox x:Name="TxtSlope"
                                         Style="{StaticResource FluentTextBox}"
                                         Text="0.005" Margin="0,0,0,4"/>
                            </StackPanel>

                            <!-- Row 1: n value hint -->
                            <StackPanel Grid.Row="1" Grid.Column="2"
                                        VerticalAlignment="Top" Margin="0,4,0,0">
                                <TextBlock x:Name="LblNHint"
                                           Style="{StaticResource FluentHint}"
                                           TextWrapping="Wrap"
                                           Text="Select a material above or type n manually."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── RESULTS ── -->
                <Border x:Name="ResultsCard" Style="{StaticResource FluentCard}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="RESULTS"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <!-- Hydrology results -->
                        <TextBlock Text="Hydrology" Foreground="{StaticResource AldtTextSecondary}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Area (acres):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="0,2"/>
                            <TextBlock x:Name="LblAcres" Grid.Row="0" Grid.Column="1"
                                       Foreground="White" FontWeight="SemiBold" Margin="12,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Q runoff (CFS):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="0,2"/>
                            <TextBlock x:Name="LblQRunoff" Grid.Row="1" Grid.Column="1"
                                       Foreground="{StaticResource AldtAccent}" FontWeight="Bold"
                                       FontSize="14" Margin="12,2"/>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource AldtBorder}" Margin="0,0,0,12"/>

                        <!-- Hydraulics results -->
                        <TextBlock Text="Hydraulics" Foreground="{StaticResource AldtTextSecondary}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="D (ft):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="0,2"/>
                            <TextBlock x:Name="LblDft" Grid.Row="0" Grid.Column="1"
                                       Foreground="White" Margin="12,2"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="A pipe (sq ft):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="16,2,0,2"/>
                            <TextBlock x:Name="LblApipe" Grid.Row="0" Grid.Column="3"
                                       Foreground="White" Margin="12,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Wetted P (ft):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="0,2"/>
                            <TextBlock x:Name="LblP" Grid.Row="1" Grid.Column="1"
                                       Foreground="White" Margin="12,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Hyd. R (ft):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="16,2,0,2"/>
                            <TextBlock x:Name="LblR" Grid.Row="1" Grid.Column="3"
                                       Foreground="White" Margin="12,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Q capacity (CFS):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="0,2"/>
                            <TextBlock x:Name="LblQCap" Grid.Row="2" Grid.Column="1"
                                       Foreground="{StaticResource AldtAccent}" FontWeight="Bold"
                                       FontSize="14" Margin="12,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Velocity (ft/s):"
                                       Foreground="{StaticResource AldtTextSecondary}" Margin="16,2,0,2"/>
                            <TextBlock x:Name="LblV" Grid.Row="2" Grid.Column="3"
                                       Foreground="{StaticResource AldtAccent}" FontWeight="Bold"
                                       FontSize="14" Margin="12,2"/>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource AldtBorder}" Margin="0,0,0,12"/>

                        <!-- Validation -->
                        <TextBlock Text="Validation" Foreground="{StaticResource AldtTextSecondary}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <Border x:Name="CapacityBorder" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,6">
                            <TextBlock x:Name="LblCapacity" TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <Border x:Name="VelocityBorder" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,4">
                            <TextBlock x:Name="LblVelocity" TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- Suggestion label -->
                        <TextBlock x:Name="LblSuggestion"
                                   Foreground="{StaticResource AldtAccent}"
                                   FontSize="12" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ── ERROR ── -->
                <Border x:Name="ErrorCard" Style="{StaticResource FluentCard}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="LblError"
                               Foreground="{StaticResource AldtError}"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
