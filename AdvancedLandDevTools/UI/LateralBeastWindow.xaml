<Window x:Class="AdvancedLandDevTools.UI.LateralBeastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lateral Beast Parameters" SizeToContent="Height" Width="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AldtBackground}" 
        FontFamily="Segoe UI"
        FontSize="13"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Target Line Layer:" Style="{StaticResource FluentFieldLabel}" Margin="0,0,10,0"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Name="cmbTargetLayer" IsEditable="True" Text="P-ROW" Style="{StaticResource FluentComboBox}" Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Direction:" Style="{StaticResource FluentFieldLabel}" Margin="0,0,10,0"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Name="cmbDirection" Style="{StaticResource FluentComboBox}" Margin="0,5">
            <ComboBoxItem Content="Left"/>
            <ComboBoxItem Content="Right" IsSelected="True"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Angle (deg):" Style="{StaticResource FluentFieldLabel}" Margin="0,0,10,0"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="txtAngle" Text="6.0" Style="{StaticResource FluentTextBox}" Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Pipe Gap (units):" Style="{StaticResource FluentFieldLabel}" Margin="0,0,10,0"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="txtGap" Text="5.0" Style="{StaticResource FluentTextBox}" Margin="0,5"/>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="80" IsCancel="True" Style="{StaticResource FluentSecondaryBtn}" Click="BtnCancel_Click"/>
            <Button Content="OK" Width="80" IsDefault="True" Style="{StaticResource FluentPrimaryBtn}" Click="BtnOk_Click" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
