<Window
    x:Class="AdvancedLandDevTools.UI.MarkFittingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Advanced Land Development Tools – Mark Fittings"
    Width="450" Height="500"
    WindowStartupLocation="CenterScreen"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AldtHeader}" Padding="20,14">
            <TextBlock Text="Select Fitting Descriptions to Mark" Foreground="{StaticResource AldtAccent}" FontSize="16" FontWeight="SemiBold"/>
        </Border>

        <Border Grid.Row="1" Padding="20" Style="{StaticResource FluentCard}">
            <ListView x:Name="DescriptionListView" Style="{StaticResource FluentListView}" SelectionMode="Extended">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                         <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                         <Setter Property="Padding" Value="0"/>
                         <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource FluentCheckBox}" Padding="4,3">
                            <TextBlock Text="{Binding Display}"/>
                        </CheckBox>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource AldtHeader}" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource FluentSecondaryBtn}" IsCancel="True" Click="BtnCancel_Click"/>
                <Button Content="Mark Selected" Style="{StaticResource FluentPrimaryBtn}" IsDefault="True" Margin="12,0,0,0" Click="BtnOk_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
