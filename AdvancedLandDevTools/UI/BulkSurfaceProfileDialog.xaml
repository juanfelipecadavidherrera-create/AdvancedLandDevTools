<Window
    x:Class="AdvancedLandDevTools.UI.BulkSurfaceProfileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Advanced Land Development Tools – Bulk Surface Profile Creator"
    Width="760" Height="680"
    MinWidth="680" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Placeholder brush (local) ──────────────────────── -->
            <SolidColorBrush x:Key="PlaceholderBrush" Color="#6A6A6A"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             HEADER
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource AldtHeader}"
                Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="38" Height="38"
                        Background="{StaticResource AldtAccentBtn}"
                        CornerRadius="8"
                        Margin="0,0,14,0">
                    <TextBlock Text="A" Foreground="White" FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADVANCED LAND DEVELOPMENT TOOLS"
                               Foreground="{StaticResource AldtAccent}" FontSize="9"
                               FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock Text="Bulk Surface Profile Creator"
                               Foreground="White" FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             BODY
             ════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,16,20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: Alignment List ──────────────────────────────── -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="ALIGNMENTS"
                               Style="{StaticResource FluentSectionTitle}"/>

                    <!-- Search box -->
                    <Grid Margin="0,0,0,8">
                        <TextBox x:Name="TxtSearch"
                                 Style="{StaticResource FluentTextBox}"
                                 TextChanged="TxtSearch_TextChanged"
                                 ToolTip="Type to filter alignments by name"/>
                        <TextBlock x:Name="TxtSearchPlaceholder"
                                   Text="Search alignments..."
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource PlaceholderBrush}"/>
                    </Grid>

                    <!-- Select All / Clear All row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnSelectAll"
                                Content="Select All"
                                Style="{StaticResource FluentSecondaryBtn}"
                                Padding="12,5"
                                FontSize="11"
                                Click="BtnSelectAll_Click"/>
                        <Button x:Name="BtnClearAll"
                                Content="Clear All"
                                Style="{StaticResource FluentSecondaryBtn}"
                                Padding="12,5"
                                FontSize="11"
                                Margin="8,0,0,0"
                                Click="BtnClearAll_Click"/>
                        <TextBlock x:Name="TxtSelCount"
                                   Text="0 selected"
                                   Foreground="{StaticResource AldtTextTertiary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Scrollable alignment checklist -->
                    <Border Style="{StaticResource FluentCard}"
                            Height="220" Padding="4,4">
                        <ListView x:Name="AlignmentListView"
                                  Style="{StaticResource FluentListView}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  SelectionMode="Extended">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource FluentCheckBox}"
                                              Padding="4,3"
                                              Checked="AlignmentCheckBox_Changed"
                                              Unchecked="AlignmentCheckBox_Changed">
                                        <TextBlock Text="{Binding Display}" TextWrapping="NoWrap"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <!-- ── Station Range card ──────────────────────────────── -->
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="STATION RANGE"
                                       Style="{StaticResource FluentSectionTitle}"
                                       Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start Station"
                                               Style="{StaticResource FluentFieldLabel}"/>
                                    <TextBox x:Name="TxtStationStart"
                                             Style="{StaticResource FluentTextBox}"
                                             Tag="Full extent"
                                             GotFocus="PlaceholderBox_GotFocus"
                                             LostFocus="PlaceholderBox_LostFocus"
                                             ToolTip="e.g.  0+00  or  0   (blank = full alignment extent)"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="End Station"
                                               Style="{StaticResource FluentFieldLabel}"/>
                                    <TextBox x:Name="TxtStationEnd"
                                             Style="{StaticResource FluentTextBox}"
                                             Tag="Full extent"
                                             GotFocus="PlaceholderBox_GotFocus"
                                             LostFocus="PlaceholderBox_LostFocus"
                                             ToolTip="e.g.  42+50  or  4250   (blank = full alignment extent)"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Leave blank to use the full extent of each alignment. Range may extend beyond alignment."
                                       Style="{StaticResource FluentHint}"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Elevation Range card ────────────────────────────── -->
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="ELEVATION RANGE"
                                       Style="{StaticResource FluentSectionTitle}"
                                       Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Min Elevation"
                                               Style="{StaticResource FluentFieldLabel}"/>
                                    <TextBox x:Name="TxtElevMin"
                                             Style="{StaticResource FluentTextBox}"
                                             Tag="Default: 2.00"
                                             GotFocus="PlaceholderBox_GotFocus"
                                             LostFocus="PlaceholderBox_LostFocus"
                                             ToolTip="e.g.  2.00   (blank = Auto)"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max Elevation"
                                               Style="{StaticResource FluentFieldLabel}"/>
                                    <TextBox x:Name="TxtElevMax"
                                             Style="{StaticResource FluentTextBox}"
                                             Tag="Default: 12.00"
                                             GotFocus="PlaceholderBox_GotFocus"
                                             LostFocus="PlaceholderBox_LostFocus"
                                             ToolTip="e.g.  50.00   (blank = Auto)"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Leave blank to let Civil 3D frame the elevation automatically."
                                       Style="{StaticResource FluentHint}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── RIGHT: Settings Panel ─────────────────────────────── -->
                <Border Grid.Column="2"
                        Style="{StaticResource FluentCard}">
                    <StackPanel>

                        <TextBlock Text="REFERENCE"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <TextBlock Text="Surface" Style="{StaticResource FluentFieldLabel}"/>
                        <ComboBox x:Name="CmbSurface"
                                  Style="{StaticResource FluentComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Margin="0,0,0,14"
                                  ToolTip="Surface to sample elevations from"/>

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource AldtBorder}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="VISUAL STYLES"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <TextBlock Text="Profile Style" Style="{StaticResource FluentFieldLabel}"/>
                        <ComboBox x:Name="CmbProfileStyle"
                                  Style="{StaticResource FluentComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Margin="0,0,0,10"
                                  ToolTip="Style for the profile line (colour, linetype)"/>

                        <TextBlock Text="Profile View Style" Style="{StaticResource FluentFieldLabel}"/>
                        <ComboBox x:Name="CmbProfileViewStyle"
                                  Style="{StaticResource FluentComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Margin="0,0,0,14"
                                  ToolTip="Style for the profile view grid"/>

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource AldtBorder}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="NAMING"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <TextBlock Text="Profile Name Suffix" Style="{StaticResource FluentFieldLabel}"/>
                        <TextBox x:Name="TxtProfileSuffix"
                                 Style="{StaticResource FluentTextBox}"
                                 Text=" - EG"
                                 Margin="0,0,0,10"
                                 ToolTip="Appended to alignment name, e.g.  CL-1 - EG"/>

                        <TextBlock Text="Profile View Name Suffix" Style="{StaticResource FluentFieldLabel}"/>
                        <TextBox x:Name="TxtPVSuffix"
                                 Style="{StaticResource FluentTextBox}"
                                 Text=" - PV"
                                 Margin="0,0,0,14"
                                 ToolTip="Appended to alignment name, e.g.  CL-1 - PV"/>

                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource AldtBorder}"
                                Margin="0,0,0,14"/>

                        <TextBlock Text="LAYOUT"
                                   Style="{StaticResource FluentSectionTitle}"/>

                        <TextBlock Text="Vertical Spacing Between Views (ft)"
                                   Style="{StaticResource FluentFieldLabel}"
                                   TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtViewSpacing"
                                 Style="{StaticResource FluentTextBox}"
                                 Text="250"
                                 ToolTip="Y-offset (feet) between consecutive profile views"/>

                        <!-- Validation message -->
                        <TextBlock x:Name="TxtValidation"
                                   Foreground="{StaticResource AldtError}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,14,0,0"
                                   Visibility="Collapsed"/>

                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ════════════════════════════════════════════════════════════════
             FOOTER
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource AldtHeader}"
                Padding="20,12">
            <Grid>
                <TextBlock x:Name="TxtFooterInfo"
                           Text="After clicking OK, pick the insertion point in the drawing."
                           Foreground="{StaticResource AldtTextTertiary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Style="{StaticResource FluentSecondaryBtn}"
                            IsCancel="True"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnOk"
                            Content="Create Profiles"
                            Style="{StaticResource FluentPrimaryBtn}"
                            IsDefault="True"
                            Margin="12,0,0,0"
                            Click="BtnOk_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
