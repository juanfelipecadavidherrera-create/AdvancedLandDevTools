<Window
    x:Class="AdvancedLandDevTools.UI.TableDrawerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Advanced Land Development Tools - Table Drawer"
    Width="1050" Height="740"
    MinWidth="820" MinHeight="580"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Body -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource AldtHeader}" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="38" Height="38"
                        Background="#27AE60"
                        CornerRadius="8" Margin="0,0,14,0">
                    <TextBlock Text="T" Foreground="White" FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADVANCED LAND DEVELOPMENT TOOLS"
                               Foreground="{StaticResource AldtAccent}" FontSize="9"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Table Drawer"
                               Foreground="{StaticResource AldtText}" FontSize="18"
                               FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Margin="24,0,0,0">
                    <TextBlock Foreground="{StaticResource AldtTextSecondary}" FontSize="10"
                               Text="Click a cell to edit · Link icon ⛓ = live data · Orange = selected"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════ BODY ═══════ -->
        <Grid Grid.Row="1" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>   <!-- Canvas -->
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="270"/>  <!-- Side panel -->
            </Grid.ColumnDefinitions>

            <!-- ─── CANVAS PREVIEW ─── -->
            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="6"
                    BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                <ScrollViewer x:Name="PreviewScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Canvas x:Name="PreviewCanvas"
                            MinWidth="300" MinHeight="200"
                            MouseLeftButtonDown="PreviewCanvas_MouseDown"/>
                </ScrollViewer>
            </Border>

            <!-- ─── SIDE PANEL ─── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Table structure -->
                    <Border Background="#282828" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="TABLE STRUCTURE"
                                       Foreground="{StaticResource AldtAccent}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rows"
                                               Foreground="{StaticResource AldtTextSecondary}"
                                               FontSize="10" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtRows" Style="{StaticResource FluentTextBox}" Text="3"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Cols"
                                               Foreground="{StaticResource AldtTextSecondary}"
                                               FontSize="10" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtCols" Style="{StaticResource FluentTextBox}" Text="3"/>
                                </StackPanel>
                            </Grid>
                            <Button Content="Apply Size"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Padding="12,6" HorizontalAlignment="Stretch"
                                    Click="BtnApplySize_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Column widths -->
                    <Border Background="#282828" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="COLUMN WIDTHS (ft)"
                                       Foreground="{StaticResource AldtAccent}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="IcColWidths">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       Foreground="{StaticResource AldtTextSecondary}"
                                                       VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="1"
                                                     Style="{StaticResource FluentTextBox}"
                                                     Text="{Binding Value}"
                                                     Tag="{Binding Index}"
                                                     LostFocus="ColWidth_LostFocus"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Row heights -->
                    <Border Background="#282828" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ROW HEIGHTS (ft)"
                                       Foreground="{StaticResource AldtAccent}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="IcRowHeights">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       Foreground="{StaticResource AldtTextSecondary}"
                                                       VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="1"
                                                     Style="{StaticResource FluentTextBox}"
                                                     Text="{Binding Value}"
                                                     Tag="{Binding Index}"
                                                     LostFocus="RowHeight_LostFocus"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Text style / height -->
                    <Border Background="#282828" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="TEXT STYLE"
                                       Foreground="{StaticResource AldtAccent}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <TextBlock Text="Style"
                                       Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbTextStyle"
                                      Style="{StaticResource FluentComboBox}"
                                      Margin="0,0,0,8"
                                      SelectionChanged="CmbTextStyle_Changed"/>

                            <TextBlock Text="Text height (ft)"
                                       Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtTextHeight"
                                     Style="{StaticResource FluentTextBox}"
                                     Text="2.5"
                                     LostFocus="TxtTextHeight_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <!-- Selected-cell editor (hidden until a cell is clicked) -->
                    <Border x:Name="CellEditorPanel"
                            Background="#282828" CornerRadius="6"
                            Padding="10" Margin="0,0,0,8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="TxtCellTitle"
                                       Text="CELL [0,0]"
                                       Foreground="{StaticResource AldtAccent}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <TextBlock Text="Cell text"
                                       Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtCellText"
                                     Style="{StaticResource FluentTextBox}"
                                     AcceptsReturn="True"
                                     MinHeight="52"
                                     Margin="0,0,0,6"
                                     TextChanged="TxtCellText_Changed"/>

                            <Button Content="⛓  Link to Entity"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Padding="10,6" HorizontalAlignment="Stretch"
                                    Margin="0,0,0,6"
                                    Click="BtnLinkEntity_Click"/>

                            <!-- Link info (shown when cell has a link) -->
                            <Border x:Name="LinkInfoPanel"
                                    Visibility="Collapsed"
                                    Background="#1E1E1E" CornerRadius="4"
                                    Padding="8" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="Linked entity:"
                                               Foreground="{StaticResource AldtTextSecondary}"
                                               FontSize="10"/>
                                    <TextBlock x:Name="TxtLinkSummary"
                                               Foreground="{StaticResource AldtText}"
                                               FontSize="11" TextWrapping="Wrap"
                                               Margin="0,2,0,4"/>
                                    <Button Content="✕  Remove link"
                                            Style="{StaticResource FluentSecondaryBtn}"
                                            Padding="8,4" HorizontalAlignment="Left"
                                            Click="BtnRemoveLink_Click"/>
                                </StackPanel>
                            </Border>

                            <Separator Background="#3A3A3A" Margin="0,4,0,6"/>

                            <TextBlock Text="MERGE"
                                       Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <Button Content="→ Right"
                                        Style="{StaticResource FluentSecondaryBtn}"
                                        Padding="8,5" Margin="0,0,4,0"
                                        Click="BtnMergeRight_Click"/>
                                <Button Content="↓ Down"
                                        Style="{StaticResource FluentSecondaryBtn}"
                                        Padding="8,5"
                                        Click="BtnMergeDown_Click"/>
                            </StackPanel>
                            <Button Content="Unmerge"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Padding="8,5" HorizontalAlignment="Left"
                                    Click="BtnUnmerge_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════ FOOTER ═══════ -->
        <Border Grid.Row="2" Background="{StaticResource AldtHeader}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Save / Load -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TxtTableName" Width="130"
                             Style="{StaticResource FluentTextBox}"
                             Tag="Table name"/>
                    <Button Content="Save" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnSave_Click"/>
                    <ComboBox x:Name="CmbSaved" Width="160" Margin="12,0,0,0"
                              Style="{StaticResource FluentComboBox}"
                              DisplayMemberPath="Name"
                              SelectionChanged="CmbSaved_Changed"/>
                    <Button Content="Load" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnLoad_Click"/>
                    <Button Content="Del" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnDelete_Click"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Draw in Model"
                            Style="{StaticResource FluentPrimaryBtn}"
                            Padding="16,6"
                            Click="BtnDraw_Click"/>
                    <Button Content="Close" Margin="8,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
