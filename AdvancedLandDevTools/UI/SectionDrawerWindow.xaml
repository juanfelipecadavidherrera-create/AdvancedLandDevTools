<Window
    x:Class="AdvancedLandDevTools.UI.SectionDrawerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Advanced Land Development Tools - Section Drawer"
    Width="820" Height="680"
    MinWidth="700" MinHeight="550"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#202020"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="FluentDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource AldtHeader}" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="38" Height="38"
                        Background="{StaticResource AldtAccentBtn}"
                        CornerRadius="8" Margin="0,0,14,0">
                    <TextBlock Text="S" Foreground="White" FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADVANCED LAND DEVELOPMENT TOOLS"
                               Foreground="{StaticResource AldtAccent}" FontSize="9"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Section Drawer"
                               Foreground="{StaticResource AldtText}" FontSize="18"
                               FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════ PREVIEW CANVAS ═══════ -->
        <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="6"
                Margin="12,8,12,4" BorderBrush="#333" BorderThickness="1"
                ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas" ClipToBounds="True"
                    SizeChanged="PreviewCanvas_SizeChanged"/>
        </Border>

        <!-- ═══════ OPTIONS ═══════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,4">
            <CheckBox x:Name="ChkSegmentLines" Content="Draw segment divider lines"
                      Foreground="{StaticResource AldtTextSecondary}"
                      VerticalContentAlignment="Center" FontSize="11"
                      IsChecked="False"
                      Checked="ChkSegmentLines_Changed"
                      Unchecked="ChkSegmentLines_Changed"/>
            <TextBlock Text="  (Toggle 'R' for road layers, 'G' for grass/earth — mutually exclusive)"
                       Foreground="{StaticResource AldtTextTertiary}"
                       VerticalAlignment="Center" FontSize="10" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- ═══════ INPUT CONTROLS ═══════ -->
        <Grid Grid.Row="3" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE -->
            <Border Grid.Column="0" Background="#282828" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="LEFT SEGMENTS"
                               Foreground="{StaticResource AldtAccent}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <ListBox Grid.Row="1" x:Name="LstLeft"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource AldtText}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Display}"
                                               Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="{Binding RoadLabel}"
                                            Width="22" Height="22" FontSize="10"
                                            Background="{Binding RoadBg}"
                                            Foreground="{Binding RoadFg}"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}" Margin="2,0"
                                            ToolTip="Toggle road layers for this segment"
                                            Click="BtnToggleLeftRoad_Click"
                                            Visibility="{Binding RoadVisible}"/>
                                    <Button Grid.Column="2" Content="{Binding GrassLabel}"
                                            Width="22" Height="22" FontSize="10"
                                            Background="{Binding GrassBg}"
                                            Foreground="{Binding GrassFg}"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}" Margin="2,0"
                                            ToolTip="Toggle grass/earth layer for this segment"
                                            Click="BtnToggleLeftGrass_Click"
                                            Visibility="{Binding GrassVisible}"/>
                                    <Button Grid.Column="3" Content="X"
                                            Width="22" Height="22" FontSize="10"
                                            Background="#442222" Foreground="#FF6B6B"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}"
                                            Click="BtnDeleteLeft_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Dist (ft)" Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Width="70"/>
                            <TextBlock Text="Slope %" Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Width="70" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtLeftDist" Width="70"
                                     Style="{StaticResource FluentTextBox}"
                                     Tag="Dist (ft)"/>
                            <TextBox x:Name="TxtLeftSlope" Width="70" Margin="6,0,0,0"
                                     Style="{StaticResource FluentTextBox}"
                                     Tag="Slope %"/>
                            <Button Content="+ Add" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddLeft_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="+ Type F (2')" Margin="0,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddLeftTypeF_Click" FontSize="11"
                                    ToolTip="Type F Curb &amp; Gutter — 2 ft"/>
                            <Button Content="+ Type D (0.5')" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddLeftTypeD_Click" FontSize="11"
                                    ToolTip="Type D Mountable Curb — 0.5 ft"/>
                            <Button Content="+ Valley (2')" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddLeftValley_Click" FontSize="11"
                                    ToolTip="Valley Gutter — 2 ft"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT SIDE -->
            <Border Grid.Column="2" Background="#282828" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="RIGHT SEGMENTS"
                               Foreground="#6BCB77"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <ListBox Grid.Row="1" x:Name="LstRight"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource AldtText}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Display}"
                                               Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="{Binding RoadLabel}"
                                            Width="22" Height="22" FontSize="10"
                                            Background="{Binding RoadBg}"
                                            Foreground="{Binding RoadFg}"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}" Margin="2,0"
                                            ToolTip="Toggle road layers for this segment"
                                            Click="BtnToggleRightRoad_Click"
                                            Visibility="{Binding RoadVisible}"/>
                                    <Button Grid.Column="2" Content="{Binding GrassLabel}"
                                            Width="22" Height="22" FontSize="10"
                                            Background="{Binding GrassBg}"
                                            Foreground="{Binding GrassFg}"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}" Margin="2,0"
                                            ToolTip="Toggle grass/earth layer for this segment"
                                            Click="BtnToggleRightGrass_Click"
                                            Visibility="{Binding GrassVisible}"/>
                                    <Button Grid.Column="3" Content="X"
                                            Width="22" Height="22" FontSize="10"
                                            Background="#442222" Foreground="#FF6B6B"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding Index}"
                                            Click="BtnDeleteRight_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Dist (ft)" Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Width="70"/>
                            <TextBlock Text="Slope %" Foreground="{StaticResource AldtTextSecondary}"
                                       FontSize="10" Width="70" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtRightDist" Width="70"
                                     Style="{StaticResource FluentTextBox}"
                                     Tag="Dist (ft)"/>
                            <TextBox x:Name="TxtRightSlope" Width="70" Margin="6,0,0,0"
                                     Style="{StaticResource FluentTextBox}"
                                     Tag="Slope %"/>
                            <Button Content="+ Add" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddRight_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="+ Type F (2')" Margin="0,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddRightTypeF_Click" FontSize="11"
                                    ToolTip="Type F Curb &amp; Gutter — 2 ft"/>
                            <Button Content="+ Type D (0.5')" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddRightTypeD_Click" FontSize="11"
                                    ToolTip="Type D Mountable Curb — 0.5 ft"/>
                            <Button Content="+ Valley (2')" Margin="6,0,0,0"
                                    Style="{StaticResource FluentSecondaryBtn}"
                                    Click="BtnAddRightValley_Click" FontSize="11"
                                    ToolTip="Valley Gutter — 2 ft"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════ FOOTER ═══════ -->
        <Border Grid.Row="4" Background="{StaticResource AldtHeader}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Save/Load controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="TxtSectionName" Width="140"
                             Style="{StaticResource FluentTextBox}"
                             Tag="Section name"/>
                    <Button Content="Save" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnSave_Click"/>
                    <ComboBox x:Name="CmbSaved" Width="140" Margin="12,0,0,0"
                              Style="{StaticResource FluentComboBox}"
                              SelectionChanged="CmbSaved_Changed"/>
                    <Button Content="Load" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnLoad_Click"/>
                    <Button Content="Del" Margin="6,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnDelete_Click"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Draw in Model"
                            Style="{StaticResource FluentPrimaryBtn}"
                            Padding="16,6" Click="BtnDraw_Click"/>
                    <Button Content="Close" Margin="8,0,0,0"
                            Style="{StaticResource FluentSecondaryBtn}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
